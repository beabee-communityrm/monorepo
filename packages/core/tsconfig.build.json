{
  "extends": "@beabee/tsconfig/tsconfig.server.json",
  "include": ["./src/**/*", "./src/**/*.json"],
  "exclude": ["./**/*.test.ts"],
  "references": [{ "path": "../common" }, { "path": "../locale" }],
  "compilerOptions": {
    "declaration": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "#locale": ["./src/locales/current.ts"],
      "#models": ["./src/models/index.ts"],
      "#models/*": ["./src/models/*.ts"],
      "#type": ["./src/type/index.ts"],
      "#type/*": ["./src/type/*.ts"],
      "#*": ["./src/*.ts"]
    }
  }
}
