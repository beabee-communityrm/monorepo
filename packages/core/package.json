{
  "name": "@beabee/core",
  "description": "Core package for the beabee backend",
  "version": "0.28.1",
  "type": "module",
  "scripts": {
    "clear": "rimraf dist/",
    "build": "tsc -p tsconfig.build.json && cp -r src/data dist/",
    "dev": "yarn watch",
    "watch": "tsc --watch --preserveWatchOutput -p tsconfig.build.json",
    "format": "prettier --write .",
    "check": "concurrently 'yarn:check:*'",
    "check:tsc": "tsc -p tsconfig.build.json --noEmit",
    "check:prettier": "prettier -c .",
    "check:typeorm-index": "yarn workspace @beabee/dev-cli start generate-class-index --baseDir $(pwd) --src ./src/models --out ./src/entities.ts --export-name entities --class-name-strategy filename --check && yarn workspace @beabee/dev-cli start generate-class-index --baseDir $(pwd) --src ./src/migrations --out ./src/migrations.ts --export-name migrations --class-name-strategy parse --check",
    "generate:index": "yarn workspace @beabee/dev-cli start generate-index --extension js --baseDir $(pwd) -p ./src/errors ./src/models ./src/services ./src/type ./src/filter-handlers ./src/templates",
    "generate:typeorm-index": "yarn workspace @beabee/dev-cli start generate-class-index --baseDir $(pwd) --src ./src/models --out ./src/entities.ts --export-name entities --class-name-strategy filename && yarn workspace @beabee/dev-cli start generate-class-index --baseDir $(pwd) --src ./src/migrations --out ./src/migrations.ts --export-name migrations --class-name-strategy parse",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist/"
  ],
  "imports": {
    "#locale": {
      "types": "./src/locales/current.ts",
      "default": "./dist/locales/current.js"
    },
    "#filter-handlers": {
      "types": "./src/filter-handlers/index.ts",
      "default": "./dist/filter-handlers/index.js"
    },
    "#filter-handlers/*": {
      "types": "./src/filter-handlers/*.ts",
      "default": "./dist/filter-handlers/*.js"
    },
    "#lib": {
      "types": "./src/lib/index.ts",
      "default": "./dist/lib/index.js"
    },
    "#lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    },
    "#models": {
      "types": "./src/models/index.ts",
      "default": "./dist/models/index.js"
    },
    "#models/*": {
      "types": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "#services": {
      "types": "./src/services/index.ts",
      "default": "./dist/services/index.js"
    },
    "#services/*": {
      "types": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "#providers/*": {
      "types": "./src/providers/*.ts",
      "default": "./dist/providers/*.js"
    },
    "#templates": {
      "types": "./src/templates/index.ts",
      "default": "./dist/templates/index.js"
    },
    "#templates/*": {
      "types": "./src/templates/*.ts",
      "default": "./dist/templates/*.js"
    },
    "#type": {
      "types": "./src/type/index.ts",
      "default": "./dist/type/index.js"
    },
    "#type/*": {
      "types": "./src/type/*.ts",
      "default": "./dist/type/*.js"
    },
    "#*": {
      "types": "./src/*.ts",
      "default": "./dist/*.js"
    }
  },
  "exports": {
    "./config": {
      "types": "./src/config/config.ts",
      "default": "./dist/config/config.js"
    },
    "./database": {
      "types": "./src/database.ts",
      "default": "./dist/database.js"
    },
    "./errors": {
      "types": "./src/errors/index.ts",
      "default": "./dist/errors/index.js"
    },
    "./filter-handlers": {
      "types": "./src/filter-handlers/index.ts",
      "default": "./dist/filter-handlers/index.js"
    },
    "./filter-handlers/*": {
      "types": "./src/filter-handlers/*.ts",
      "default": "./dist/filter-handlers/*.js"
    },
    "./locale": {
      "types": "./src/locales/current.ts",
      "default": "./dist/locales/current.js"
    },
    "./logging": {
      "types": "./src/logging.ts",
      "default": "./dist/logging.js"
    },
    "./models": {
      "types": "./src/models/index.ts",
      "default": "./dist/models/index.js"
    },
    "./models/*": {
      "types": "./src/models/*.ts",
      "default": "./dist/models/*.js"
    },
    "./type": {
      "types": "./src/type/index.ts",
      "default": "./dist/type/index.js"
    },
    "./server": {
      "types": "./src/server.ts",
      "default": "./dist/server.js"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    },
    "./services": {
      "types": "./src/services/index.ts",
      "default": "./dist/services/index.js"
    },
    "./services/*": {
      "types": "./src/services/*.ts",
      "default": "./dist/services/*.js"
    },
    "./providers/*": {
      "types": "./src/providers/*.ts",
      "default": "./dist/providers/*.js"
    },
    "./templates": {
      "types": "./src/templates/index.ts",
      "default": "./dist/templates/index.js"
    },
    "./templates/*": {
      "types": "./src/templates/*.ts",
      "default": "./dist/templates/*.js"
    },
    "./utils": {
      "types": "./src/utils/index.ts",
      "default": "./dist/utils/index.js"
    },
    "./utils/*": {
      "types": "./src/utils/*.ts",
      "default": "./dist/utils/*.js"
    },
    "./tools/*": {
      "types": "./src/tools/*.ts",
      "default": "./dist/tools/*.js"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1043.0",
    "@aws-sdk/s3-request-presigner": "^3.1043.0",
    "@beabee/beabee-common": "workspace:^",
    "@beabee/locale": "workspace:^",
    "@sendgrid/mail": "^8.1.6",
    "axios": "^1.16.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "date-fns": "^4.1.0",
    "express": "^4.22.1",
    "express-winston": "^4.2.0",
    "gocardless-nodejs": "^4.8.2",
    "gunzip-maybe": "^1.4.2",
    "jsonwebtoken": "^9.0.3",
    "juice": "^11.1.1",
    "moment": "^2.30.1",
    "nodemailer": "^6.10.1",
    "otpauth": "^9.5.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "rate-limiter-flexible": "^7.4.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.10.4",
    "sharp": "^0.34.5",
    "slugify": "^1.6.9",
    "stripe": "^15.12.0",
    "svgo": "^3.3.3",
    "tar-stream": "^3.2.0",
    "typeorm": "^0.3.28",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "yaml-front-matter": "^4.1.1"
  },
  "devDependencies": {
    "@beabee/prettier-config": "workspace:^",
    "@beabee/tsconfig": "workspace:^",
    "@types/gunzip-maybe": "^1.4.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/nodemailer": "^6.4.23",
    "@types/passport": "^1.0.17",
    "@types/passport-local": "^1.0.38",
    "@types/sharp": "^0.32.0",
    "@types/tar-stream": "^3.1.4",
    "@types/yaml-front-matter": "^4.1.3",
    "concurrently": "^9.2.1",
    "prettier": "^3.8.3",
    "rimraf": "^6.1.3",
    "tsconfig": "^7.0.0",
    "typescript": "~6.0.3",
    "vitest": "^3.2.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/beabee-communityrm/monorepo.git"
  },
  "author": "",
  "license": "AGPL-3.0",
  "bugs": {
    "url": "https://github.com/beabee-communityrm/monorepo/issues"
  },
  "homepage": "https://github.com/beabee-communityrm/monorepo/blob/main/packages/core/README.md"
}
