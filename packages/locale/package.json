{
  "name": "@beabee/locale",
  "description": "Beabee Locale Translations",
  "version": "0.28.1",
  "type": "module",
  "homepage": "https://github.com/beabee-communityrm/monorepo/tree/main/packages/locale",
  "license": "CC-BY-4.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/beabee-communityrm/monorepo/tree/main/packages/locale"
  },
  "scripts": {
    "clear": "rm -rf dist/ tsconfig.tsbuildinfo",
    "build": "tsc -p ./tsconfig.build.json && node ./scripts/build.mjs",
    "watch": "tsc -p ./tsconfig.build.json --watch --preserveWatchOutput",
    "dev": "yarn watch",
    "prepublishOnly": "yarn clear && yarn build",
    "check": "yarn check:tsc && yarn check:prettier",
    "check:tsc": "tsc --noEmit",
    "check:prettier": "prettier -c .",
    "format": "prettier --write .",
    "generate:index": "yarn workspace @beabee/dev-cli start generate-index --baseDir $(pwd) --extension js -p ./src/types"
  },
  "devDependencies": {
    "@beabee/prettier-config": "workspace:^",
    "prettier": "^3.8.3",
    "typescript": "~6.0.3"
  },
  "files": [
    "dist/",
    "src/"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "./package.json": "./package.json",
    "./locales/*": "./src/locales/*.json",
    "./locales-with-fallback/*": "./src/locales/*.json",
    "./locales": {
      "types": "./dist/locales/index.d.ts",
      "default": "./dist/locales/index.js"
    },
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  }
}
