{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireBranch": "main",
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}",
    "autoGenerate": true
  },
  "npm": {
    "publish": false
  },
  "hooks": {
    "before:init": ["yarn check", "yarn build"]
  },
  "plugins": {
    "@release-it/bumper": {
      "out": ["package.json", "packages/*/package.json", "apps/*/package.json"]
    }
  }
}
