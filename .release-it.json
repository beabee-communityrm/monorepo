{
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "requireBranch": "main",
    "requireCleanWorkingDir": true
  },
  "github": {
    "release": true,
    "releaseName": "v${version}"
  },
  "npm": {
    "publish": false
  },
  "hooks": {
  },
  "plugins": {
    "@release-it/bumper": {
      "out": ["package.json", "packages/*/package.json", "apps/*/package.json"]
    },
    "@release-it/conventional-changelog": {
      "preset": {
        "name": "conventionalcommits",
        "types": [
          { "type": "feat" },
          { "type": "fix" },
          { "type": "perf" },
          { "type": "revert" },
          { "type": "chore" },
          { "type": "refactor" },
          { "type": "docs" },
          { "type": "test" },
          { "type": "build" },
          { "type": "ci" }
        ]
      },
      "infile": "CHANGELOG.md",
      "header": "# Changelog",
      "gitRawCommitsOpts": {
        "merges": true,
        "no-merges": false
      }
    }
  }
}
