{
  "extends": "@beabee/tsconfig/tsconfig.frontend.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.tsx",
    "src/**/*.vue",
    "auto-imports.d.ts",
    "components.d.ts"
  ],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "rootDir": ".",
    "paths": {
      "#components/*": ["./src/components/*"],
      "#composables/*": ["./src/composables/*"],
      "#layouts/*": ["./src/layouts/*"],
      "#lib/*": ["./src/lib/*"],
      "#pages/*": ["./src/pages/*"],
      "#store/*": ["./src/store/*"],
      "#type/*": ["./src/type/*"],
      "#utils/*": ["./src/utils/*"],
      "#enums/*": ["./src/enums/*"],

      "#components": ["./src/components/index"],
      "#layouts": ["./src/layouts/index"],
      "#lib": ["./src/lib/index"],
      "#pages": ["./src/pages/index"],
      "#store": ["./src/store/index"],
      "#type": ["./src/type/index"],
      "#utils": ["./src/utils/index"],
      "#enums": ["./src/enums/index"],

      "#env": ["./src/env"],
      "#assets/*": ["./src/assets/*"]
    }
  },
  "vueCompilerOptions": {
    "plugins": [
      "vue-router/volar/sfc-route-blocks",
      "vue-router/volar/sfc-typed-router"
    ]
  }
}
